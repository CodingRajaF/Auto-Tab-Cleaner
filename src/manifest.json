{
    "manifest_version": 3,
    "name": "Auto Tab Cleaner",
    "version": "0.1.0",
    "permissions": ["storage", "tabs", "alarms"],
    "background": { "service_worker": "background.js" },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "action": {
        "default_popup": "options.html",
        "default_title": "Auto Tab Cleaner"
    }
}